      "cell_type": "code",
      "source": [
        "import ydf\n",
        "import pandas as pd\n",
        "import numpy as np"
      ],
      "metadata": {
        "id": "1CQl6yXlEwFw"
      },
      "execution_count": 1,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def split_dataset(ds, test_ratio):\n",
        "  test_indices = np.random.rand(len(ds)) < test_ratio\n",
        "  return ds[~test_indices], ds[test_indices]\n",
        "\n",
        "crime_dataset = pd.read_csv(\"./Crime_Data_from_2020_to_2024.csv\")\n",
        "crime_dataset = crime_dataset.drop(columns = [\"Status Desc\"])\n",
        "crime_dataset = crime_dataset.dropna(subset=["Status"])\n",
        "crime_train, crime_test = split_dataset(crime_dataset, 0.10)\n",
        "print(len(crime_train), len(crime_test))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "G8HS5nTjEz8G",
        "outputId": "d3f34d5f-75a3-4acd-9c18-64e5752381b2"
      },
      "execution_count": 27,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "904283 100611\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "crime_IC = crime_train[crime_train[\"Status\"] == \"IC\"]\n",
        "crime_CC = crime_train[crime_train[\"Status\"] == \"CC\"]\n",
        "crime_AA = crime_train[crime_train[\"Status\"] == \"AA\"]\n",
        "crime_AO = crime_train[crime_train[\"Status\"] == \"AO\"]\n",
        "crime_JA = crime_train[crime_train[\"Status\"] == \"JA\"]\n",
        "crime_JO = crime_train[crime_train[\"Status\"] == \"JO\"]"
      ],
      "metadata": {
        "id": "BzqFF6DfWPO_"
      },
      "execution_count": 28,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "len(crime_IC), len(crime_CC), len(crime_AA), len(crime_AO), len(crime_JA), len(crime_JO)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "3Y_4kJT3acO5",
        "outputId": "8cfb0057-0ade-4547-af72-e52e98188b92"
