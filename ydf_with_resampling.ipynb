    {
      "cell_type": "code",
      "source": [
        "crime_resample = pd.concat([crime_IC_keep, crime_AA, crime_AO_keep, crime_JA_dup, crime_JO_dup])\n",
        "crime_resample = crime_resample.sample(frac = 1).reset_index(drop=True) # reshuffle\n",
        "crime_resample.head(20)"
      ],
