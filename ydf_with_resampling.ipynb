    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "\n",
        "crime_IC_keep, crime_IC_toss = split_dataset(crime_IC, 0.889) # keep 1/9th of ICs\n",
        "crime_AO_keep, crime_AO_toss = split_dataset(crime_AO, 0.2) # keep 4/5ths of AO\n",
        "crime_JA_dup = pd.concat([crime_JA]*27) # repeat JA 27 times\n",
        "crime_JO_dup = pd.concat([crime_JO]*48) # repeat JO 48 times\n",
        "\n",
        "len(crime_IC_keep), len(crime_AA), len(crime_AO_keep), len(crime_JA_dup), len(crime_JO_dup)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
